  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:login": "babel src/login.jsx --out-file public/dist/login.js",
    "build:index": "babel src/app.jsx --out-file public/dist/index.js",
    "build:correcao": "babel src/correcao_cadastral.jsx --out-file public/dist/correcao_cadastral.js",
    "build:tailwind": "tailwindcss -i ./src/input.css -o ./public/dist/tailwind.css",
    "build:all": "npm run build:login && npm run build:index && npm run build:correcao && npm run build:tailwind"
  },
  "dependencies": {
    "acorn": "^8.17.0",
    "adm-zip": "^0.5.17",
    "bcrypt": "^6.0.0",
    "body-parser": "^1.20.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "iconv-lite": "^0.7.3",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "node-fetch": "^3.3.2",
    "pg": "^8.21.0",
    "pg-copy-streams": "^7.0.0",
    "react": "^19.2.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@babel/cli": "^7.22.10",
    "@babel/core": "^7.22.9",
    "@babel/preset-env": "^7.22.10",
    "@babel/preset-react": "^7.22.5",
    "autoprefixer": "^10.5.2",
    "nodemon": "^3.0.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2"
  }
